# In local dev, leave these unset — the app auto-detects the Metro host (your
# machine's LAN IP) so it works on a physical device, simulator, and emulator.
# Set EXPO_PUBLIC_API_URL only to target a fixed backend (staging/prod).
# EXPO_PUBLIC_API_URL=https://api.staging.moto.example
# EXPO_PUBLIC_API_PORT=3000

# Google Sign-In (OAuth client IDs from console.cloud.google.com → Credentials).
# All from ONE Google Cloud project. The backend's GOOGLE_CLIENT_ID must list
# the same IDs (comma-separated). Unset = the Google button stays disabled.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxx.apps.googleusercontent.com
