{
  "expo": {
    "name": "Moto",
    "slug": "moto",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "moto",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moto.app"
    },
    "android": {
      "package": "com.moto.app"
    },
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Moto to access your photos to set your profile and bike photos.",
          "cameraPermission": "Allow Moto to use the camera to take profile and bike photos."
        }
      ]
    ]
  }
}
